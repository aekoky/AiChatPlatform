# .NET Environment
ASPNETCORE_ENVIRONMENT=Development

# RabbitMQ
RabbitMQ__Uri=amqp://rabbitmq:LUUcvHJHv22GE7e@rabbitmq:5672

# Keycloak
Keycloak__Authority=http://host.docker.internal:8080/realms/aichat
Keycloak__Audience=aichat-web

# Databases
ConnectionStrings__Marten=Host=postgres;Port=5432;Database=aichat;Username=postgres;Password=postgres
ConnectionStrings__Postgres=Host=postgres;Port=5432;Database=documents;Username=postgres;Password=postgres

# S3 Object Storage (MinIO)
S3__Endpoint=http://minio:9000
S3__AccessKey=minioadmin
S3__SecretKey=minioadmin
S3__Bucket=documents
S3__ForcePathStyle=true

# Ollama LLM
Ollama__BaseUrl=http://ollama:11434
Ollama__Model=llama3
Ollama__EmbeddingModel=nomic-embed-text
Ollama__TimeoutSeconds=600

# OpenAI (Fallback/External AI)
OpenAI__ApiKey=your_openai_api_key_here
OpenAI__Model=gpt-4.1

# Document Ingestion / Kreuzberg Parser
KreuzbergParser__EnableChunking=true
KreuzbergParser__ChunkMaxChars=2000
KreuzbergParser__ChunkOverlap=200
KreuzbergParser__EnableOcr=false
KreuzbergParser__OcrBackend=tesseract
KreuzbergParser__OcrLanguage=eng
KreuzbergParser__EnableLanguageDetection=false
KreuzbergParser__UseCache=true
KreuzbergParser__EnableQualityProcessing=true
